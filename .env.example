SECRET=change-me-to-a-long-random-secret
BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qr_codes

# Google OAuth client id for ID-token verification (from the provisioning slice).
GOOGLE_CLIENT_ID=

# Session cookie (ADR 0009). Set SESSION_COOKIE_SECURE=false only for local HTTP
# dev; production must serve over HTTPS with it true. SESSION_MAX_AGE is seconds.
SESSION_COOKIE_SECURE=true
SESSION_MAX_AGE=1209600
